              "clawrecipes/verify-built-in-team-recipes",
              "clawrecipes/releasing"
            ]
          },
          {
            "group": "ClawKitchen",
            "pages": [
              "clawkitchen/index",
              "clawkitchen/product-tour",
              "clawkitchen/install-and-access",
